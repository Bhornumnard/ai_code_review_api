APP_ENV=development
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./app.db

# Default provider used when request.provider is omitted.
DEFAULT_LLM_PROVIDER=openai

# JSON array of provider credentials.
# provider values: openai, claude (or anthropic), gemini
LLM_PROVIDER_KEYS=[{"provider":"openai","key":"YOUR_OPENAI_KEY"},{"provider":"claude","key":"YOUR_ANTHROPIC_KEY"},{"provider":"gemini","key":"YOUR_GEMINI_KEY"}]

# Initial admin account for /admin/auth/login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-admin-password
ADMIN_JWT_SECRET=change-this-admin-secret-to-long-random-value
ADMIN_JWT_ALGORITHM=HS256
ADMIN_ACCESS_TOKEN_EXPIRE_MINUTES=15
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5

# Global per-key rate limit.
RATE_LIMIT_REQUESTS_PER_MINUTE=10
